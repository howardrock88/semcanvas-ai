# SemCanvas AI runtime
HOST=127.0.0.1
PORT=4321

# Image provider: codex | openai | custom
# codex uses the local Codex CLI and does not require API credentials.
IMAGE_PROVIDER=codex
# Timeout for local Codex CLI image generation/editing calls.
CODEX_TIMEOUT_MS=720000

# OpenAI Images API provider
# See: https://platform.openai.com/docs/guides/image-generation
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_IMAGES_BASE_URL=https://api.openai.com/v1

# Custom HTTP provider, useful for nano-banana, ComfyUI wrappers, or your own gateway.
# Endpoint should accept JSON and return one of:
# - { "imageDataUrl": "data:image/png;base64,..." }
# - { "imageBase64": "..." }
# - { "url": "https://..." }
# - { "path": "/absolute/local/file.png" }
IMAGE_API_ENDPOINT=
IMAGE_API_KEY=
IMAGE_MODEL=

# Segmentation backend: auto | fastsam | sam | fallback
SEGMENT_BACKEND=auto
SAM_DEVICE=cpu
SAM_MAX_DIM=768
FASTSAM_MAX_DIM=768
